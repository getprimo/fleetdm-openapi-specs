{
  "openapi": "3.1.0",
  "info": {
    "title": "Fleet REST API",
    "version": "1.0.0",
    "description": "REST API for Fleet device management platform. Paths and schemas are generated from live API responses; see README.",
    "contact": {
      "name": "Fleet",
      "url": "https://fleetdm.com"
    }
  },
  "servers": [
    {
      "url": "{protocol}://{host}",
      "description": "Fleet server",
      "variables": {
        "protocol": {
          "default": "https",
          "enum": ["https", "http"]
        },
        "host": {
          "default": "api.fleetdm.com"
        }
      }
    }
  ],
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "API token authentication. Get your token from My Account > Get API token in the Fleet UI."
      }
    },
    "schemas": {}
  },
  "paths": {}
}
