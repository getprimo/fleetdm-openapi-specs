{
  "name": "fleetdm-openapi-generator",
  "version": "1.0.0",
  "description": "Autonomous OpenAPI 3.1 spec for the Fleet REST API, generated and kept honest from live API responses",
  "scripts": {
    "validate": "tsx src/validate/run.ts",
    "validate:write": "tsx src/validate/run.ts --write"
  },
  "keywords": [
    "fleetdm",
    "openapi",
    "api",
    "typescript",
    "zod"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
